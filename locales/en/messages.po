msgid "start_message"
msgstr "👋 Hello! I'm a crypto analytics bot.\n\nI receive news in real-time and determine which ones caused price movements. Such news is published in the channel.\n\n📊 Available commands:\n/btc — BTC price, fear/greed, dominance\n/whales — latest whale transactions\n/liquidations — latest liquidations\n/funding — funding rates\n/latest — last 5 news\n/historical BTC — Bitcoin news archive\n/international ko — news from Korea\n/ask What about ETF? — ask AI\n/factcheck [text] — fact checking\n/summarize [url] — summary\n/entities [text] — entity extraction\n/gainers — top gainers\n/losers — top losers\n/coin ethereum — coin info\n/heatmap — market heatmap\n/options — options data\n/orderbook BTC/USD — order book\n/feargreed — fear & greed index\n/dominance — BTC and ETH dominance\n/subscribe — manage subscriptions\n/language — change language"

msgid "btc_price"
msgstr "💰 **Bitcoin (BTC)**\nPrice: ${price:,.2f}\n\n😨 Fear & Greed Index: **{fear}**\n({fear_class})\n📊 BTC Dominance: {btc_dom:.2f}%\n📊 ETH Dominance: {eth_dom:.2f}%"

