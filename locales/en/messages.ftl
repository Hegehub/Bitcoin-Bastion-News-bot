start_message = 👋 Hello! I'm a crypto analytics bot.\n\nI receive news in real-time and determine which ones caused price movements. Such news is published in the channel.\n\n📊 Available commands:\n/btc — BTC price, fear/greed, dominance\n/whales — latest whale transactions\n/liquidations — latest liquidations\n/funding — funding rates\n/latest — last 5 news\n/historical BTC — Bitcoin news archive\n/international ko — news from Korea\n/ask What about ETF? — ask AI\n/factcheck [text] — fact checking\n/summarize [url] — summary\n/entities [text] — entity extraction\n/gainers — top gainers\n/losers — top losers\n/coin ethereum — coin info\n/heatmap — market heatmap\n/options — options data\n/orderbook BTC/USD — order book\n/feargreed — fear & greed index\n/dominance — BTC and ETH dominance\n/subscribe — manage subscriptions\n/language — change language\n/backtest — run backtest (admin)
btc_price = 💰 <b>Bitcoin (BTC)</b>\nPrice: <code>${price:,.2f}</code>\n\n😨 Fear & Greed Index: <b>{fear}</b> ({fear_class})\n📊 BTC Dominance: <b>{btc_dom:.2f}%</b>\n📊 ETH Dominance: <b>{eth_dom:.2f}%</b>
whales_title = 🐋 <b>Latest Whale Transactions:</b>\n\n
whale_entry = • <code>{amount:.2f} {coin}</code> (${value:,.0f})\n  From: <code>{from_addr}</code> → To: <code>{to_addr}</code>\n  <a href='{url}'>Tx</a>\n\n
liquidations_title = 💥 <b>Latest Liquidations:</b>\n\n
liquidation_entry = {emoji} {side} <code>{amount:,.0f}$</code> on {pair}\n
funding_title = 💰 <b>Funding Rates (8h):</b>\n\n
funding_entry = {emoji} {pair}: <code>{rate}%</code>\n
latest_news_title = 📰 <b>Latest News:</b>\n\n
historical_news_title = 📚 <b>Historical News Archive for {ticker}:</b>\n\n
international_news_title = 🌍 <b>International News ({lang}):</b>\n\n
ask_response = 🤖 <b>AI Response:</b>\n\n<blockquote>{response}</blockquote>
ask_prompt = What would you like to ask about crypto?
summarize_prompt = Send me a news URL to summarize:
summary_result = 📝 <b>Summary:</b>\n\n<blockquote>{summary}</blockquote>
factcheck_prompt = Send me a claim to fact-check:
factcheck_result = 🔍 <b>Fact Check Result:</b>\n\n{result}
entities_prompt = Send me text to extract entities from:
entities_result = 🔬 <b>Extracted Entities:</b>\n\n{entities}
movers_title = 📈 <b>Top {type}:</b>\n\n
mover_entry = {emoji} <code>{symbol}</code>: {change:+.2f}% (${price})\n
coin_prompt = Enter coin name (e.g., bitcoin, ethereum):
coin_info = 🪙 <b>{name} ({symbol})</b>\n💰 Price: <code>${price:,.2f}</code>\n📊 Market Cap: <code>${market_cap:,.0f}</code>\n📈 Volume (24h): <code>${volume:,.0f}</code>\n🔄 Circulating Supply: <code>{circulating_supply:,.0f}</code>\n🏆 Market Rank: <code>#{rank}</code>\n\n{description}
heatmap_title = 🔥 <b>Market Heatmap</b>\n(green = gain, red = loss)
options_title = 📊 <b>Options Data</b>\n\n{data}
orderbook_prompt = Enter trading pair (e.g., BTC/USD):
orderbook_title = 📚 <b>Order Book {pair}</b>\n\nBids:\n{bids}\n\nAsks:\n{asks}
feargreed = 😨 Fear & Greed Index: <b>{value}</b> — {classification}
dominance = 📊 BTC Dominance: <b>{btc:.2f}%</b>\n📊 ETH Dominance: <b>{eth:.2f}%</b>
subscribe_menu = 🔔 <b>Manage Subscriptions:</b>\n\nChoose notification types:
language_selected = ✅ Language changed to English
error_occurred = ❌ An error occurred. Please try again later.
no_data = ❌ Failed to retrieve data.
